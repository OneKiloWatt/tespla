# Local development environment variables.
# Copy this file to .env.local and fill in the values.
# DO NOT use these values in production — generate new secrets for each environment.

POSTGRES_PASSWORD=
POSTGRES_DB=postgres
SUPABASE_DB_USER=supabase_admin

# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=

# Generate ANON_KEY and SERVICE_ROLE_KEY from your JWT_SECRET using:
# https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
ANON_KEY=
SERVICE_ROLE_KEY=

# Optional: pin image tags here instead of relying on moving tags.
# SUPABASE_AUTH_IMAGE=supabase/gotrue:<pin>
# SUPABASE_REALTIME_IMAGE=supabase/realtime:<pin>
# SUPABASE_STORAGE_IMAGE=supabase/storage-api:<pin>
# SUPABASE_META_IMAGE=supabase/postgres-meta:<pin>
# SUPABASE_STUDIO_IMAGE=supabase/studio:<pin>

SUPABASE_PUBLIC_URL=http://localhost:54321
SUPABASE_SITE_URL=http://localhost:3000

SUPABASE_API_PORT=54321
SUPABASE_DB_PORT=54322
SUPABASE_STUDIO_PORT=54323

# Optional overrides
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_EXTERNAL_EMAIL_ENABLED=false
GOTRUE_MAILER_AUTOCONFIRM=true

STUDIO_ORGANIZATION_NAME=Local
STUDIO_PROJECT_NAME=test-allocation-planner

STORAGE_BUCKET=local
STORAGE_REGION=local
STORAGE_TENANT_ID=stub
STORAGE_FILE_SIZE_LIMIT=52428800

REALTIME_SECRET_KEY_BASE=realtime-secret-key-base-32-chars
REALTIME_ERLANG_COOKIE=realtime-erlang-cookie
SUPABASE_REALTIME_APP_NAME=supabase-realtime
SUPABASE_REALTIME_ERL_AFLAGS=-proto_dist inet_tcp
